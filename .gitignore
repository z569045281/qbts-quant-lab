# ── Secrets ─────────────────────────────────────────
.env
.env.*
*.env
*_secret*
*credentials*
backend/.env

# ── Python ──────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
.venv-*/
*.egg-info/
.pytest_cache/

# ── Node ────────────────────────────────────────────
node_modules/
.next/
out/

# ── Data / cache (regenerable) ──────────────────────
backend/data/cache/
backend/data/leaderboard.json
backend/data/favorites.json
*.parquet
*.jsonl

# ── AWS SAM (Route A deploy) ────────────────────────
aws/.aws-sam/
aws/samconfig.toml

# ── OS / editor ─────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp

# one-off migrations (now under sql/; some carry local seed data).
# Canonical schema lives in sql/supabase_schema.sql (tracked); the per-feature
# *_migration.sql are run once in the Supabase SQL editor and not committed.
sql/*_migration.sql
