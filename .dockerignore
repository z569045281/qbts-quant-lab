.github
.venv
.venv-1
frontend
**/__pycache__
*.pyc
# never bake secrets or local state into the image
.env
.env.*
*_secret*
*credentials*
backend/data/cache
*.parquet
*.jsonl
leaderboard.json
favorites.json
# SAM build output
aws/.aws-sam
